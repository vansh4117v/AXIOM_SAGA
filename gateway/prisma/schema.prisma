
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  username       String    @unique @db.VarChar(100)
  email          String    @unique @db.VarChar(255)
  passwordHash   String?   @map("password_hash") @db.VarChar(255)
  role           String    @default("viewer") @db.VarChar(50)
  isActive       Boolean   @default(true) @map("is_active")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastLoginAt    DateTime? @map("last_login_at")

  // OAuth fields
  googleId       String?   @unique @map("google_id") @db.VarChar(255)
  avatarUrl      String?   @map("avatar_url") @db.VarChar(500)
  authProvider   String    @default("local") @map("auth_provider") @db.VarChar(50) // "local" | "google"

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  refreshTokens  RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at")
  revoked    Boolean   @default(false)
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  userAgent  String?   @map("user_agent") @db.VarChar(500)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Ticket {
  id           Int       @id @default(autoincrement())
  ticketKey    String    @unique @map("ticket_key") @db.VarChar(50)
  jiraIssueId  String?   @unique @map("jira_issue_id") @db.VarChar(50)
  rawPayload   Json      @map("raw_payload")
  ticketDto    Json      @map("ticket_dto")
  status       String    @default("pending") @db.VarChar(50)
  receivedAt   DateTime  @default(now()) @map("received_at")
  processedAt  DateTime? @map("processed_at")

  briefings    Briefing[]

  @@map("tickets")
}

model Briefing {
  id                 Int      @id @default(autoincrement())
  runId              String   @default(dbgenerated("gen_random_uuid()")) @map("run_id") @db.Uuid
  ticketKey          String   @map("ticket_key") @db.VarChar(50)
  scratchpad         Json
  briefing           Json
  agentTrace         Json     @map("agent_trace")
  overallConfidence  Float?   @map("overall_confidence")
  executionPlan      String[] @map("execution_plan")
  createdAt          DateTime @default(now()) @map("created_at")

  ticket             Ticket   @relation(fields: [ticketKey], references: [ticketKey])

  @@map("briefings")
}

model AgentPrompt {
  id           Int      @id @default(autoincrement())
  agentName    String   @unique @map("agent_name") @db.VarChar(100)
  systemPrompt String   @map("system_prompt") @db.Text
  version      Int      @default(1)
  updatedAt    DateTime @default(now()) @map("updated_at")
  updatedBy    String?  @map("updated_by") @db.VarChar(100)

  @@map("agent_prompts")
}

model TeamMember {
  id                  Int      @id @default(autoincrement())
  teamName            String   @map("team_name") @db.VarChar(100)
  memberName          String   @map("member_name") @db.VarChar(100)
  role                String?  @db.VarChar(100)
  githubHandle        String?  @map("github_handle") @db.VarChar(100)
  domains             String[]
  ownedPaths          String[] @map("owned_paths")
  escalationPriority  Int      @default(1) @map("escalation_priority")

  @@map("team_registry")
}

model CodeEmbedding {
  id          Int      @id @default(autoincrement())
  repo        String   @db.VarChar(255)
  filePath    String   @map("file_path") @db.VarChar(512)
  chunkText   String   @map("chunk_text") @db.Text
  // pgvector column — Prisma can't model this natively.
  // Use prisma.$queryRaw for vector search.
  // embedding vector(1024) added via raw SQL migration.
  lastUpdated DateTime @default(now()) @map("last_updated")

  @@unique([repo, filePath])
  @@map("code_embeddings")
}

model JiraPollState {
  id             Int      @id @default(autoincrement())
  lastPolledAt   DateTime @default(now()) @map("last_polled_at")
  lastTicketKey  String?  @map("last_ticket_key") @db.VarChar(50)

  @@map("jira_poll_state")
}
