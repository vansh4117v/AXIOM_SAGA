# ─── Jira Integration ──────────────────────────────────────────
JIRA_BASE_URL=https://yourteam.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ
JIRA_POLL_CRON=*/1 * * * *
JIRA_POLL_MAX_RESULTS=20
JIRA_POLL_LOOKBACK_MINUTES=2
JIRA_REQUEST_TIMEOUT=15000

# ─── AI Engine ─────────────────────────────────────────────────
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_TIMEOUT=10000

# ─── Authentication ────────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=1800000

# ─── Database (same Azure PostgreSQL as AI engine) ─────────────
DATABASE_URL=postgresql://user:pass@host:5432/sage
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_SSL=false

# ─── Server ────────────────────────────────────────────────────
GATEWAY_PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ─── Deduplicator ──────────────────────────────────────────────
DEDUP_MAX_SIZE=10000
DEDUP_TTL_MS=3600000
DEDUP_CLEANUP_INTERVAL_MS=300000

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
